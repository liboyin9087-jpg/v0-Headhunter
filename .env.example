# ==============================================================
# Headhunter - Environment Variables Example
# Copy this file to .env.local and fill in your own values.
# ==============================================================

# ---- Supabase ----------------------------------------------------
# Get these from https://supabase.com/dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# (Optional) Override the OAuth / magic-link redirect URL during local dev.
# When unset, the app falls back to window.location.origin/auth/callback.
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# ---- AI Provider (Moonshot, OpenAI-compatible) -------------------
# Required for /api/ai/analyze. Without this the AI Matching page returns 500.
# Sign up at https://platform.moonshot.cn/
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================
# Database schema is defined in scripts/001_create_tables.sql
# Run it in your Supabase SQL editor once after creating a project.
# ==============================================================
